<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Hero section with gradient -->
        <LinearLayout
            android:id="@+id/heroSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_hero_gradient"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="24dp"
            android:paddingBottom="32dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/backButton"
                style="@style/Widget.App.Button.TonalGlass"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginBottom="8dp"
                android:minWidth="0dp"
                android:minHeight="0dp"
                android:paddingHorizontal="0dp"
                android:paddingVertical="0dp"
                android:text="←"
                android:textSize="22sp"
                app:cornerRadius="20dp" />

            <TextView
                android:id="@+id/heroEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textSize="72sp"
                tools:text="🍣" />

            <TextView
                android:id="@+id/heroTitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textAppearance="@style/TextAppearance.App.HeroTitleLarge"
                tools:text="Sushi" />

            <TextView
                android:id="@+id/heroSubtitle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:textAppearance="@style/TextAppearance.App.HeroSubtitle"
                tools:text="From Japan" />

            <TextView
                android:id="@+id/heroBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_chip_rounded"
                android:paddingHorizontal="14dp"
                android:paddingVertical="6dp"
                android:textAppearance="@style/TextAppearance.App.Badge"
                android:textColor="@color/meal_default_fg"
                tools:text="LUNCH/DINNER" />

        </LinearLayout>

        <!-- Quick info cards -->
        <LinearLayout
            android:id="@+id/quickInfoRow"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="-24dp"
            android:baselineAligned="false"
            android:orientation="horizontal" />

        <!-- Description card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/descriptionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="About"
                    android:textAppearance="@style/TextAppearance.App.SectionLabel" />

                <TextView
                    android:id="@+id/descriptionText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textAppearance="@style/TextAppearance.App.Body"
                    tools:text="A Japanese dish of prepared vinegared rice accompanied by various ingredients such as seafood and vegetables." />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Raw properties card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="All properties"
                    android:textAppearance="@style/TextAppearance.App.SectionLabel" />

                <LinearLayout
                    android:id="@+id/allPropertiesContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="vertical" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
