<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_bg">

    <!-- Compact hero header -->
    <LinearLayout
        android:id="@+id/heroHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_hero_gradient"
        android:orientation="vertical"
        android:paddingHorizontal="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/backButton"
            style="@style/Widget.App.Button.TonalGlass"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingHorizontal="0dp"
            android:paddingVertical="0dp"
            android:text="←"
            android:textSize="22sp"
            app:cornerRadius="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="Security Audit"
            android:textAppearance="@style/TextAppearance.App.HeroGreeting" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Vulnerable Endpoints"
            android:textAppearance="@style/TextAppearance.App.HeroTitle" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="OWASP API Top 10 — NIT3213 dummy API"
            android:textAppearance="@style/TextAppearance.App.HeroSubtitle" />

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="24dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/heroHeader">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="20dp">

            <!-- Warning / context banner -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFF3E0"
                app:strokeColor="@color/brand_primary"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="⚠️"
                        android:textSize="22sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Educational Security Demo"
                            android:textAppearance="@style/TextAppearance.App.SectionLabel" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="This screen live-tests OWASP API Top 10 vulnerabilities against the NIT3213 course API at nit3213api.onrender.com. It is a dummy API intended for class demonstrations — no real user data is exposed."
                            android:textAppearance="@style/TextAppearance.App.CardSubtitle" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ============================================ -->
            <!-- Section 1: Broken Object Level Authorization -->
            <!-- ============================================ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="8dp"
                android:text="API1:2023 — Broken Object Level Authorization"
                android:textAppearance="@style/TextAppearance.App.SectionLabel" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Unauthenticated Dashboards"
                        android:textAppearance="@style/TextAppearance.App.CardTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="The endpoint GET /dashboard/{topic} returns full datasets without requiring any authentication token, keypass, or session. Any HTTP client can enumerate topics and harvest data. Tap any topic below to fetch live data — you are NOT logged in."
                        android:textAppearance="@style/TextAppearance.App.CardSubtitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:fontFamily="monospace"
                        android:text="curl https://nit3213api.onrender.com/dashboard/food"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textColor="@color/brand_primary" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/topicChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        app:singleSelection="true" />

                    <ProgressBar
                        android:id="@+id/topicProgressBar"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="12dp"
                        android:indeterminateTint="@color/brand_primary"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/topicResultHeader"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:textAppearance="@style/TextAppearance.App.SectionLabel"
                        android:visibility="gone"
                        tools:text="/food — 7 of 7 entities (no auth token used)"
                        tools:visibility="visible" />

                    <LinearLayout
                        android:id="@+id/topicResultContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="vertical"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/topicErrorText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textColor="@android:color/holo_red_dark"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ================================================ -->
            <!-- Section 2: Broken Authentication (Enumeration)  -->
            <!-- ================================================ -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="24dp"
                android:layout_marginBottom="8dp"
                android:text="API2:2023 — Broken Authentication"
                android:textAppearance="@style/TextAppearance.App.SectionLabel" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Student ID Enumeration"
                        android:textAppearance="@style/TextAppearance.App.CardTitle" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:text="The /sydney/auth login endpoint returns different HTTP status codes depending on whether a student ID exists, which lets an attacker enumerate valid accounts by brute-force:"
                        android:textAppearance="@style/TextAppearance.App.CardSubtitle" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:background="@color/surface_bg"
                        android:orientation="vertical"
                        android:padding="12dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="monospace"
                            android:text="• 400 Bad Request — user EXISTS (wrong password)"
                            android:textAppearance="@style/TextAppearance.App.Caption"
                            android:textColor="@color/meal_lunch_fg" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="monospace"
                            android:text="• 404 Not Found   — user does NOT exist"
                            android:textAppearance="@style/TextAppearance.App.Caption" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:fontFamily="monospace"
                            android:text="• 200 OK          — credentials correct (keypass)"
                            android:textAppearance="@style/TextAppearance.App.Caption"
                            android:textColor="@color/meal_snack_fg" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Combined with no rate limiting on the auth endpoint, this allows an attacker to discover the full list of registered student IDs."
                        android:textAppearance="@style/TextAppearance.App.CardSubtitle" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Starting student ID"
                        android:textAppearance="@style/TextAppearance.App.SectionLabel" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="s"
                            android:textAppearance="@style/TextAppearance.App.Body"
                            android:textSize="16sp" />

                        <com.google.android.material.textfield.TextInputLayout
                            style="@style/Widget.App.TextInputLayout"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:hint="Start ID"
                            app:boxCornerRadiusBottomEnd="10dp"
                            app:boxCornerRadiusBottomStart="10dp"
                            app:boxCornerRadiusTopEnd="10dp"
                            app:boxCornerRadiusTopStart="10dp">

                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/scanStartInput"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:inputType="number"
                                android:text="8131100" />

                        </com.google.android.material.textfield.TextInputLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="8dp"
                            android:text="→ ∞"
                            android:textAppearance="@style/TextAppearance.App.Caption"
                            android:textSize="18sp" />

                    </LinearLayout>

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Fires 128 parallel HTTP probes against /sydney/auth. Hit Stop whenever you have seen enough."
                        android:textAppearance="@style/TextAppearance.App.Caption" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/scanButton"
                        style="@style/Widget.App.Button.Primary"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Start Enumeration Scan" />

                    <LinearLayout
                        android:id="@+id/scanProgressContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:visibility="gone">

                        <ProgressBar
                            android:id="@+id/scanProgressBar"
                            style="@android:style/Widget.ProgressBar.Horizontal"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:indeterminate="true"
                            android:indeterminateTint="@color/brand_primary" />

                        <TextView
                            android:id="@+id/scanProgressText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:textAppearance="@style/TextAppearance.App.Caption"
                            tools:text="Scanned: 140  •  Found: 2" />

                    </LinearLayout>

                    <TextView
                        android:id="@+id/scanResultsLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:textAppearance="@style/TextAppearance.App.SectionLabel"
                        android:visibility="gone"
                        tools:text="Students that fetched the API"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/scanResultsText"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="6dp"
                        android:background="@color/surface_bg"
                        android:fontFamily="monospace"
                        android:padding="12dp"
                        android:textAppearance="@style/TextAppearance.App.Caption"
                        android:textColor="@color/text_primary"
                        android:visibility="gone"
                        tools:text="s8131175\ns8131176\ns8131199"
                        tools:visibility="visible" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
