<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.App.Card.Item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <FrameLayout
            android:id="@+id/avatarCircle"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_avatar_circle"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/avatarEmoji"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:textSize="28sp" />

        </FrameLayout>

        <TextView
            android:id="@+id/titleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.App.CardTitle"
            app:layout_constraintEnd_toStartOf="@id/badgeChip"
            app:layout_constraintStart_toEndOf="@id/avatarCircle"
            app:layout_constraintTop_toTopOf="@id/avatarCircle"
            tools:text="Sushi" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.App.CardSubtitle"
            app:layout_constraintEnd_toStartOf="@id/badgeChip"
            app:layout_constraintStart_toEndOf="@id/avatarCircle"
            app:layout_constraintTop_toBottomOf="@id/titleText"
            tools:text="Japan • Rice" />

        <TextView
            android:id="@+id/badgeChip"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_chip_rounded"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:textAppearance="@style/TextAppearance.App.Badge"
            android:textColor="@color/meal_default_fg"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/avatarCircle"
            tools:text="LUNCH/DINNER" />

        <TextView
            android:id="@+id/descriptionPreview"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.App.CardDescription"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/avatarCircle"
            tools:text="A Japanese dish of prepared vinegared rice accompanied by various ingredients such as seafood and vegetables." />

        <TextView
            android:id="@+id/readMoreLink"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:paddingVertical="4dp"
            android:text="Read more →"
            android:textAppearance="@style/TextAppearance.App.ReadMore"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/descriptionPreview"
            tools:visibility="visible" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
