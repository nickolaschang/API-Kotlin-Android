<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- ========== TEXT APPEARANCES ========== -->

    <!-- On-brand hero typography (white text on gradient) -->
    <style name="TextAppearance.App.HeroGreeting" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="android:alpha">0.85</item>
    </style>

    <style name="TextAppearance.App.HeroTitle" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_on_brand</item>
    </style>

    <style name="TextAppearance.App.HeroTitleLarge" parent="TextAppearance.App.HeroTitle">
        <item name="android:textSize">34sp</item>
    </style>

    <style name="TextAppearance.App.HeroSubtitle" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="android:alpha">0.9</item>
    </style>

    <style name="TextAppearance.App.StatNumber" parent="TextAppearance.Material3.HeadlineSmall">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_on_brand</item>
    </style>

    <style name="TextAppearance.App.StatLabel" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textColor">@color/text_on_brand</item>
        <item name="android:alpha">0.9</item>
    </style>

    <!-- On-surface typography -->
    <style name="TextAppearance.App.SectionLabel" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_primary</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="android:textAllCaps">true</item>
    </style>

    <style name="TextAppearance.App.CardTitle" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textSize">18sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.App.CardSubtitle" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.App.CardDescription" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.App.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textSize">15sp</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>

    <style name="TextAppearance.App.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="TextAppearance.App.Badge" parent="TextAppearance.Material3.LabelSmall">
        <item name="android:textSize">11sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.06</item>
    </style>

    <style name="TextAppearance.App.ReadMore" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textSize">12sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/brand_primary</item>
    </style>

    <!-- ========== WIDGET STYLES ========== -->

    <style name="Widget.App.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="Widget.App.Card.Item">
        <item name="android:layout_marginHorizontal">16dp</item>
        <item name="android:layout_marginVertical">6dp</item>
        <item name="android:clickable">true</item>
        <item name="android:focusable">true</item>
        <item name="android:foreground">?android:attr/selectableItemBackground</item>
        <item name="rippleColor">@color/brand_primary</item>
    </style>

    <style name="Widget.App.Button.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>

    <style name="Widget.App.Button.TonalGlass" parent="Widget.Material3.Button.TonalButton">
        <item name="backgroundTint">#33000000</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">14dp</item>
    </style>

    <!-- NOTE: boxStrokeColor and hintTextColor are intentionally NOT set here.
         They require a ColorStateList resource; passing a flat color can
         cause TextInputLayout to silently fail to inflate on some Material
         versions. Instead, they inherit from the theme's colorPrimary, which
         already points at brand_primary. -->
    <style name="Widget.App.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>

    <style name="Widget.App.TextInputLayout.Dropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
    </style>

    <style name="Widget.App.Chip.Filter" parent="Widget.Material3.Chip.Filter">
        <item name="chipBackgroundColor">@color/card_bg</item>
        <item name="chipStrokeColor">@color/divider</item>
        <item name="chipStrokeWidth">1dp</item>
    </style>

</resources>
